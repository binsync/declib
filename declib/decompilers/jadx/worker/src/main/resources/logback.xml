<!-- Keep the worker's stdout reserved for its JSONL protocol. This resource
     takes precedence over the STDOUT logger bundled in JADX's all-in-one JAR. -->
<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%-5level - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="WARN">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
